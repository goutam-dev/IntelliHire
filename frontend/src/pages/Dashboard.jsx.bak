import React, { useEffect, useMemo, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { LayoutDashboard, Briefcase, Users, TrendingUp, Plus, FileText } from 'lucide-react';
import EmployerHeader from '../components/layout/EmployerHeader';
import { useAppDispatch, useAppSelector } from '../store/hooks';
import { fetchEmployerJobs } from '../store/slices/jobSlice';
import SiteFooter from '../components/layout/SiteFooter';

const API_BASE = import.meta.env.VITE_API_BASE || '/api';

const StatCard = ({ icon: Icon, label, value, accent = 'bg-blue-100 text-blue-700' }) => (
  <div className="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div className={`inline-flex items-center justify-center rounded-xl ${accent} p-2`}>
      <Icon className="h-5 w-5" />
    </div>
    <div>
      <p className="text-2xl font-semibold text-slate-900">{value}</p>
      <p className="text-xs uppercase tracking-wide text-slate-500">{label}</p>
    </div>
  </div>
);

const StatusBadge = ({ status }) => {
  const map = {
    active: 'bg-emerald-100 text-emerald-700',
    draft: 'bg-slate-100 text-slate-700',
    closed: 'bg-rose-100 text-rose-700',
    archived: 'bg-slate-100 text-slate-700',
  };
  return (
    <span className={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ${map[status] || 'bg-slate-100 text-slate-700'}`}>{status}</span>
  );
};

const Dashboard = () => {
  const navigate = useNavigate();
  const dispatch = useAppDispatch();
  const { jobs, jobsLoading } = useAppSelector((state) => state.job);

  const [recentApplications, setRecentApplications] = useState([]);
  const [appsLoading, setAppsLoading] = useState(false);

  useEffect(() => {
    dispatch(fetchEmployerJobs());
  }, [dispatch]);

  // Fetch applications for the most recent active job to showcase recent activity
  useEffect(() => {
    const loadRecent = async () => {
      try {
        setAppsLoading(true);
        const sorted = [...jobs].sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
        const firstActive = sorted.find((j) => j.status === 'active') || sorted[0];
        if (!firstActive?._id) {
          setRecentApplications([]);
          return;
        }
        const res = await fetch(`${API_BASE}/employer/jobs/${firstActive._id}/applications?status=all&sort=newest`);
        if (!res.ok) throw new Error('Failed to load applications');
        const data = await res.json();
        setRecentApplications(data.slice(0, 5));
      } catch (err) {
        setRecentApplications([]);
      } finally {
        setAppsLoading(false);
      }
    };
    if (jobs?.length) loadRecent();
  }, [jobs]);

  const stats = useMemo(() => {
    const total = jobs.length;
    const active = jobs.filter((j) => j.status === 'active').length;
    const draft = jobs.filter((j) => j.status === 'draft').length;
    const closed = jobs.filter((j) => j.status === 'closed').length;
    const totalApplications = jobs.reduce((sum, j) => sum + (j.applicationsCount || 0), 0);
    return { total, active, draft, closed, totalApplications };
  }, [jobs]);

  const recentJobs = useMemo(() => {
    return [...jobs]
      .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
      .slice(0, 5);
  }, [jobs]);

  return (
    <div className="min-h-screen bg-slate-50">
      <EmployerHeader />
      <main className="mx-auto max-w-7xl px-4 py-6 space-y-6">
        {/* Hero */}
        <section className="rounded-3xl bg-gradient-to-br from-indigo-50 via-sky-50 to-teal-50 border border-slate-200 p-6 flex items-center gap-6">
          <div className="rounded-2xl bg-white p-3 border border-slate-200 shadow-sm">
            <LayoutDashboard className="h-8 w-8 text-slate-700" />
          </div>
          <div className="flex-1">
            <h1 className="text-2xl font-semibold text-slate-900">Employer Dashboard</h1>
            <p className="text-sm text-slate-600">Track jobs, applications, and recent activity at a glance.</p>
          </div>
          <div className="flex flex-wrap gap-2">
            <button
              onClick={() => navigate('/employer/jobs/create')}
              className="inline-flex items-center gap-2 rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow hover:bg-slate-800"
            >
              <Plus className="h-4 w-4" /> Post a Job
            </button>
            <button
              onClick={() => navigate('/employer/jobs')}
              className="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
            >
              <Briefcase className="h-4 w-4" /> Manage Jobs
            </button>
          </div>
        </section>

        {/* Stats */}
        <section className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <StatCard icon={Briefcase} label="Total Jobs" value={stats.total} accent="bg-indigo-100 text-indigo-700" />
          <StatCard icon={TrendingUp} label="Active" value={stats.active} accent="bg-emerald-100 text-emerald-700" />
          <StatCard icon={FileText} label="Draft" value={stats.draft} accent="bg-slate-100 text-slate-700" />
          <StatCard icon={Users} label="Applications" value={stats.totalApplications} accent="bg-sky-100 text-sky-700" />
        </section>

        {/* Status distribution chart (simple bars) */}
        <section className="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 className="text-lg font-semibold text-slate-900">Pipeline Overview</h2>
          <p className="text-sm text-slate-600">Jobs by status</p>
          <div className="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
            {[{label:'Active', value: stats.active, color:'bg-emerald-500'}, {label:'Draft', value: stats.draft, color:'bg-slate-500'}, {label:'Closed', value: stats.closed, color:'bg-rose-500'}].map(({label, value, color}) => (
              <div key={label} className="space-y-2">
                <div className="flex items-center justify-between">
                  <span className="text-sm text-slate-700">{label}</span>
                  <span className="text-sm font-semibold text-slate-900">{value}</span>
                </div>
                <div className="h-2 w-full rounded-full bg-slate-100">
                  <div className={`h-2 rounded-full ${color}`} style={{ width: `${stats.total ? Math.round((value / stats.total) * 100) : 0}%` }} />
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Recent Jobs */}
        <section className="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div className="flex items-center justify-between">
            <h2 className="text-lg font-semibold text-slate-900">Recent Jobs</h2>
            <button onClick={() => navigate('/employer/jobs')} className="text-sm font-medium text-slate-700 hover:text-slate-900">View all</button>
          </div>
          <div className="mt-4 divide-y divide-slate-100">
            {jobsLoading && <div className="p-3 text-sm text-slate-600">Loading jobs…</div>}
            {!jobsLoading && recentJobs.map((job) => (
              <div key={job._id} className="py-3 flex items-center justify-between">
                <div>
                  <p className="text-sm font-medium text-slate-900">{job.title}</p>
                  <p className="text-xs text-slate-500">{new Date(job.createdAt).toLocaleDateString()} · {job.department || 'General'}</p>
                </div>
                <div className="flex items-center gap-3">
                  <StatusBadge status={job.status} />
                  <button
                    onClick={() => navigate(`/employer/jobs/${job._id}/applications`)}
                    className="inline-flex items-center gap-2 rounded-full border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50"
                  >
                    <Users className="h-4 w-4" /> View Applications
                  </button>
                </div>
              </div>
            ))}
            {!jobsLoading && recentJobs.length === 0 && (
              <div className="p-3 text-sm text-slate-600">No jobs yet. Create your first posting.</div>
            )}
          </div>
        </section>

        {/* Recent Applications */}
        <section className="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 className="text-lg font-semibold text-slate-900">Recent Applications</h2>
          {appsLoading && <div className="mt-3 text-sm text-slate-600">Loading applications…</div>}
          {!appsLoading && (
            <div className="mt-3 divide-y divide-slate-100">
              {recentApplications.map((app) => (
                <div key={app._id} className="py-3 flex items-center justify-between">
                  <div>
                    <p className="text-sm font-medium text-slate-900">{app?.candidate?.user?.fullName || 'Candidate'}</p>
                    <p className="text-xs text-slate-500">{app.status} · {app?.job?.title || ''}</p>
                  </div>
                  <button
                    onClick={() => navigate(`/employer/jobs/${app?.job?._id || ''}/applications`)}
                    className="inline-flex items-center gap-2 rounded-full border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50"
                  >
                    <FileText className="h-4 w-4" /> Review
                  </button>
                </div>
              ))}
              {recentApplications.length === 0 && (
                <div className="text-sm text-slate-600">No recent applications found.</div>
              )}
            </div>
          )}
        </section>
      </main>
      <SiteFooter />
    </div>
  );
};

export default Dashboard;