# Server Configuration
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/intellihire

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Clerk Authentication
# Get these from https://dashboard.clerk.com/
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Clerk Webhook Secret (for webhook signature verification)
# Get this from Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET=your_webhook_secret_here
# ==========================================
# AI-Powered Resume Ranking Configuration
# ==========================================

# ----- Ranking Method Toggle -----
# Set to 'false' to use original LLM Council (4 AI agents)
# Set to 'true' to use Hybrid Ranking (fast, deterministic, no LLM needed)
# Default: true (recommended for consistency and speed)
USE_HYBRID_RANKING=true

# ----- AI API Provider (only used when USE_HYBRID_RANKING=false) -----
# Options: 'groq' (recommended - FREE & FAST), 'openrouter' (free), 'huggingface' (free), 'openai' (paid), 'local' (ollama)
AI_API_PROVIDER=groq

# ----- Groq Configuration (FREE & VERY FAST - Recommended) -----
# Get your FREE API key: https://console.groq.com/keys
# Groq offers the fastest inference speeds with free tier
GROQ_API_KEY=your_groq_api_key_here

# Recommended free models:
# - llama-3.3-70b-versatile (recommended - best quality)
# - llama-3.1-70b-versatile (fast & reliable)
# - mixtral-8x7b-32768 (good balance)
GROQ_MODEL=llama-3.3-70b-versatile

# ----- Voice Proctoring Service (Python speaker verification) -----
# URL of the voice verification service (voice_verification_only/server.py)
VOICE_SERVICE_URL=http://localhost:8000

# ----- OpenRouter Configuration (FREE TIER - Alternative) -----
# Get your FREE API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Free models (no credit card required):
# - mistralai/mistral-small-3.1-24b-instruct:free
# - liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Application URL (required for OpenRouter)
APP_URL=http://localhost:5173

# ----- Alternative: HuggingFace (FREE) -----
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ----- Alternative: OpenAI (PAID) -----
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo