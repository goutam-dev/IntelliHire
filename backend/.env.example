# Server Configuration
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/intellihire

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Clerk Authentication
# Get these from https://dashboard.clerk.com/
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Clerk Webhook Secret (for webhook signature verification)
# Get this from Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET=your_webhook_secret_here
# ==========================================
# AI-Powered Resume Ranking Configuration
# ==========================================

# ----- AI API Provider -----
# Options: 'openrouter' (recommended FREE), 'huggingface' (free), 'openai' (paid), 'local' (ollama), 'rule-based' (no AI)
AI_API_PROVIDER=openrouter

# ----- OpenRouter Configuration (FREE TIER) -----
# Get your FREE API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Free models (no credit card required):
# - liquid/lfm-2.5-1.2b-instruct:free (recommended - fast & efficient)
# - allenai/molmo-2-8b:free (vision support)
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# Application URL (required for OpenRouter)
APP_URL=http://localhost:5173

# ----- Alternative: HuggingFace (FREE) -----
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ----- Alternative: OpenAI (PAID) -----
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo